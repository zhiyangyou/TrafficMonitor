    COMBOBOX        IDC_CBO_AGGREGATE_MODE, 50, 58, 100, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "单 session：", IDC_STATIC, 15, 80, 50, 10
    COMBOBOX        IDC_CBO_SINGLE_SESSION, 70, 78, 120, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "刷新 sessions", IDC_BTN_REFRESH_SESSIONS, 200, 78, 100, 14
