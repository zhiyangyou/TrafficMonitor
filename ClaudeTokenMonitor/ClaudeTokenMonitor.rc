    LTEXT           "Cache Read：", IDC_STATIC, 15, 142, 60, 10
    CONTROL         "",IDC_CLR_CACHE_READ,"MFCColorButton",WS_TABSTOP,80,140,30,14
    LTEXT           "Token Out：", IDC_STATIC, 130, 142, 60, 10
    CONTROL         "",IDC_CLR_OUTPUT,"MFCColorButton",WS_TABSTOP,195,140,30,14    GROUPBOX        "其他", IDC_STATIC, 7, 166, 306, 30
    LTEXT           "刷新频率(ms)：", IDC_STATIC, 15, 180, 70, 10
